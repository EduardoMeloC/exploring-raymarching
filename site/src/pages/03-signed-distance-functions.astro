import Article from '../layouts/Article.astro';
import { Code } from 'astro:components';
import { getAdjacentChapters } from '../data/chapters';

const { prev, next } = getAdjacentChapters('03-signed-distance-functions');

// ── Code samples ──────────────────────────────────────────────────────────────
const codeCircleSphere = `float circleDistance(vec2 point, float radius){
    return length(point) - radius;
}

float sphereDistance(vec3 point, float radius){
    return length(point) - radius;
}`;

const codeColoringCircle = `vec3 plainColor (in float d){
     return vec3(1.0) - sign(d)*vec3(0.4);
}

void mainImage( out vec4 fragColor, in vec2 fragCoord )
{
    vec2 uv = (2.*fragCoord.xy-iResolution.xy)/min(iResolution.x, iResolution.y);

    float d = circleDistance(uv, 0.5);

    vec3 col = plainColor(d);
    fragColor = vec4(col,1.0);
}`;

const codeRectangleBox = `float rectangleDistance( in vec2 p, in vec2 b ){
    vec2 d = abs(p)-b;
    return length(max(d,0.0)) + min(max(d.x,d.y),0.0);
}

float boxDistance( in vec3 p, in vec3 b ){
    vec3 d = abs(p)-b;
    return length(max(d,0.0)) + min(max(d.x,d.y,d.z),0.0);
}`;

const codeTranslateSphere = `float transformedSphere(vec3 point)
{
    return sphereDistance(point - vec3(0., 3., 0.));
}`;

const codeAffineTransform = `float transformedSphere(vec3 point)
{
    // Scale 2X along Y
    mat4 S = mat4(
        vec4(1., 0., 0., 0.),
        vec4(0., 2., 0., 0.),
        vec4(0., 0., 1., 0.),
        vec4(0., 0., 0., 1.)
    );
    // Rotation in XY
    float t = PI/4.;
    mat4 R = mat4(
        vec4(cos(t), sin(t), 0., 0.),
        vec4(-sin(t), cos(t), 0., 0.),
        vec4(0., 0., 1., 0.),
        vec4(0., 0., 0., 1.)
    );
    // Translate to (-2., -1., -1.)
    mat4 T = mat4(
        vec4(1., 0., 0., -2.),
        vec4(0., 1., 0., -1.),
        vec4(0., 0., 1., -1.),
        vec4(0., 0., 0., 1.)
    );

    mat4 transformationMatrix = S * R * T;
    vec3 transformedPoint = (vec4(point, 1.) * inverse(transformationMatrix)).xyz;

    return sphereDistance(transformedPoint);
}`;

const codeUnionEtc = `float unionOperation( float d1, float d2 )
{
    return min(d1,d2);
}
float intersectionOperation( float d1, float d2 )
{
    return max(d1,d2);
}
float subtractionOperation( float d1, float d2 )
{
    return max(-d1,d2);
}`;

const codeDisplacement = `float displacementOperation( in sdf3d sdfShape, in vec3 p )
{
    float d1 = sdfShape(p);
    float d2 = displacement(p);
    return d1+d2;
}`;

const codeWaveDistortion = `float distortedSphereDistance(vec3 p){
    float sphereRadius = 2.0;
    vec3 sphereCenter = vec3(0., 2., -5.);
    float sphereDist = length(p - sphereCenter) - sphereRadius;

    vec2 uv = sphereUV(point, sphereCenter); // spherical coordinate angles
    float distortion = sin(uv.x * 64.) * cos(uv.y * 64.); // wave pattern
    sphereDist += distortion * 0.1; // apply displacement

    return sphereDist;
}`;

// ── Math strings (set:html bypasses JSX text node compilation issues with \) ──
const mathCircleSDF    = String.raw`$$\text{CircleSDF}(\mathbf{p}) = \|\mathbf{p}\| - r$$`;
const mathSphereSDF    = String.raw`$$\text{SphereSDF}(\mathbf{p}) = \|\mathbf{p}\| - r$$`;
const mathH            = String.raw`$$h = \frac{\max(k - \|\mathbf{a} - \mathbf{b}\|,\; 0.0)}{k}$$`;
const mathC            = String.raw`$$c = \frac{h^n \cdot k}{2n}$$`;
const mathRepDomain    = String.raw`$\mathbf{p} - \textit{gap} \cdot \mathrm{round}\!\left(\frac{\mathbf{p}}{\textit{gap}}\right)$`;
const mathGradUnit     = String.raw`A key property of SDFs is that their gradient has length $1$ everywhere in space. When two SDFs are added, this property is violated — the gradient no longer has unit length, effectively "bending" space. This can cause the raymarcher to underestimate or overestimate the true distance to a surface.`;

const pCircleDim  = String.raw`The only difference is the dimension of the query point $\mathbf{p}$. In the case of a circle, $\mathbf{p}$ is a two-dimensional vector; for a sphere, $\mathbf{p}$ is a three-dimensional vector. The formula is structurally identical because both objects are defined by a center and a radius in their respective spaces.`;
const pRectSymm   = String.raw`The rectangle SDF is defined at the origin $(0,0)$. Due to the rectangle's symmetry, it is convenient to work within the first Cartesian quadrant. $\mathbf{b}$ (half each box's side) is subtracted from $\text{abs}(\mathbf{p})$, yielding a point $\mathbf{d}$. As illustrated in Figure 11:`;
const pRectInner  = String.raw`When both $\mathbf{d}.x$ and $\mathbf{d}.y$ are clamped to zero, <code>length(max(d, 0.0))</code> gives the corner distance for all outer sections. For the interior (where that expression is always 0), the SDF must return the negative distance to the nearest edge via <code>min(max(d.x, d.y), 0.0)</code>. This generalizes directly to $\mathbb{R}^3$ for the box SDF.`;
const pRectFour   = String.raw`If expanded to $\mathbb{R}^4$, the SDF can help visualize forms such as the tesseract (the 4D hypercube) by fixing and scrolling through one of the four axes.`;
const pTranslate  = String.raw`All primitives described above are centered at the origin. To perform a transformation such as scaling, rotation, or translation, it is possible to apply the <em>inverse</em> transformation at the query point $\mathbf{p}$ — transforming space rather than the shape directly.`;
const pTransCode5 = String.raw`In Code 5, by subtracting the vector $(0, 3, 0)$, the sphere is effectively positioned at $(0, 3, 0)$.`;
const liUnion     = String.raw`Taking the <strong>minimum</strong> between $\mathbf{d_1}$ and $\mathbf{d_2}$ renders only the closest surface from both objects — the union.`;
const liInter     = String.raw`Taking the <strong>maximum</strong> means nothing outside the intersection of both objects is visible, since the ray march only considers a hit if both SDF results are below the hit threshold.`;
const liSubtr     = String.raw`Taking the maximum between $\mathbf{-d_1}$ and $\mathbf{d_2}$ intersects with the inverse of object 1, resulting in the subtraction of object 1 from object 2.`;
const pSmoothK    = String.raw`Because it is fast and does not overestimate distances, the <strong>quadratic polynomial</strong> is less prone to visual artifacts and is the most widely used version for Ray Marching. Similarly to the regular <code>min</code> function, <code>smin</code> (Smooth Minimum) takes inputs $\mathbf{a}$, $\mathbf{b}$, and the threshold $k$ — blending starts where the distance between $\mathbf{a}$ and $\mathbf{b}$ is smaller than $k$.`;
const pSmoothH    = String.raw`All polynomial methods start by finding the $h()$ function, which ramps from 0 to 1 as $|\mathbf{a} - \mathbf{b}|$ goes from $k$ down to 0:`;
const pSmoothC    = String.raw`Next, a correction term $c$ is applied such that $\min(\mathbf{a},\mathbf{b}) - c$ produces the smoothed curve. For the quadratic version ($n = 2$):`;
const pSmoothEnd  = String.raw`Squaring $h$ makes $c$ ease into its peak rather than following a straight ramp. Multiplying by $k$ compensates for variation as $k$ increases. For smooth maximum, $\max(\mathbf{a},\mathbf{b}) + c$ suffices.`;
const pRepeat     = String.raw`This can also be used in 3D. Given that $\mathbf{p}$ represents the query point, the repeated domain can be expressed as <span set:html=${JSON.stringify(mathRepDomain)}></span>, where <em>gap</em> is the size of the repeated domain box.`;
const pDomGrad    = String.raw`A key property of SDFs is that their gradient has length $1$ everywhere in space. When two SDFs are added, this property is violated — the gradient no longer has unit length, effectively "bending" space. This can cause the raymarcher to underestimate or overestimate the true distance to a surface. This issue can be attenuated by reducing the step size, though at a performance cost. In practice, small deviations rarely produce noticeable artifacts, making displacement through function addition still useful for subtle surface detail.`;
const liRect1 = String.raw`If only $\mathbf{d}.x < 0$, $\mathbf{p}$ is above the rectangle — the shortest distance is straight down.`;
const liRect2 = String.raw`If only $\mathbf{d}.y < 0$, $\mathbf{p}$ is next to the rectangle — the shortest distance is straight left.`;
const liRect3 = String.raw`If both $\mathbf{d}.x < 0$ and $\mathbf{d}.y < 0$, the point is inside — the shortest distance is the closest of the two sides.`;
const liRect4 = String.raw`If neither component is negative, the point lies diagonally outside — the distance to the corner is the shortest.`;
const pGenForm = String.raw`The general form of an SDF function includes:`;
const liP      = String.raw`$\mathbf{p}$, the <strong>query point</strong>, for which the distance from the shape positioned at the origin is computed.`;
const liParams = String.raw`Shape-specific parameters, such as the <strong>radius</strong> for circles and spheres, or additional properties like <strong>width, height, or orientation</strong> for more complex geometries.`;
const pCircle2D = String.raw`For a circle centered at the origin in $\mathbb{R}^2$ with radius $r$, the SDF is:`;
const pSphere3D = String.raw`A sphere in three-dimensional space follows the same principle. If the sphere is centered at the origin with radius $r$:`;
